  "item": [
    {
      "name": "Auth Login",
      "request": {
        "method": "POST",
        "header": [
          {"key": "Content-Type", "value": "application/json"}
        ],
        "url": {"raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api","auth","login"]},
        "body": {"mode": "raw", "raw": "{\n  \"tenantId\": \"{{tenantId}}\",\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"}
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "pm.test('Has correlation id header', function () { pm.expect(pm.response.headers.has('X-Correlation-Id')).to.be.true; });",
              "pm.test('Has correlation id in body', function () { pm.expect(json.correlationId).to.exist; });"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
