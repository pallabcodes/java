        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 429) {",
              "  const json = pm.response.json();",
              "  pm.test('Error code RATE_LIMITED', function () { pm.expect(json.errorCode).eql('RATE_LIMITED'); });",
              "  pm.test('Retry-After present', function () { pm.expect(pm.response.headers.has('Retry-After')).to.be.true; });",
              "} else { pm.test('Received 429 under pressure', function () { pm.expect(false, 'Not rate limited').to.be.true; }); }"
            ],
            "type": "text/javascript"
          }
        }
      ]
    }
