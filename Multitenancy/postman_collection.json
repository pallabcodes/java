{
  "info": {
    "name": "Netflix Productivity Platform",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Authenticated, tenant aware requests. Use collection variables: baseUrl, tenantId, email, password, jwt."
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "tenantId", "value": "tenantA" },
    { "key": "email", "value": "admin@tenantA.io" },
    { "key": "password", "value": "password" },
    { "key": "jwt", "value": "" },
    { "key": "refreshToken", "value": "" }
  ],
  "item": [
    {
      "name": "Auth / Login",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-Tenant-ID", "value": "{{tenantId}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "login"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const res = pm.response.json();",
              "pm.collectionVariables.set('jwt', res.data && res.data.token ? res.data.token : res.token || '');",
              "pm.test('JWT present', function () { pm.expect(pm.collectionVariables.get('jwt')).to.have.length.above(10); });"
            ]
          }
        }
      ]
    },
    {
      "name": "Auth / Reset Request",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-Tenant-ID", "value": "{{tenantId}}" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"tenantId\": \"{{tenantId}}\",\n  \"email\": \"{{email}}\"\n}" },
        "url": { "raw": "{{baseUrl}}/api/auth/reset-request", "host": ["{{baseUrl}}"], "path": ["api", "auth", "reset-request"] }
      }
    },
    {
      "name": "Auth / Reset Confirm",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-Tenant-ID", "value": "{{tenantId}}" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"tenantId\": \"{{tenantId}}\",\n  \"token\": \"REPLACE_WITH_TOKEN\",\n  \"newPassword\": \"NewP@ssword1\"\n}" },
        "url": { "raw": "{{baseUrl}}/api/auth/reset-confirm", "host": ["{{baseUrl}}"], "path": ["api", "auth", "reset-confirm"] }
      }
    },
    {
      "name": "Auth / Refresh",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-Tenant-ID", "value": "{{tenantId}}" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"tenantId\": \"{{tenantId}}\",\n  \"refreshToken\": \"{{refreshToken}}\",\n  \"userAgent\": \"Postman\",\n  \"ip\": \"127.0.0.1\"\n}" },
        "url": { "raw": "{{baseUrl}}/api/auth/refresh", "host": ["{{baseUrl}}"], "path": ["api", "auth", "refresh"] }
      },
      "event": [
        { "listen": "test", "script": { "type": "text/javascript", "exec": [
          "const res = pm.response.json();",
          "if (res && res.data) {",
          "  if (res.data.refreshToken) pm.collectionVariables.set('refreshToken', res.data.refreshToken);",
