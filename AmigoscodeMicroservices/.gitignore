# ===========================================
# NETFLIX PRODUCTION-GRADE MICROSERVICES .GITIGNORE
# ===========================================
# This .gitignore is designed for a Netflix production-grade microservices platform
# ===========================================

# ===========================================
# JAVA & JVM
# ===========================================
# Compiled class files
*.class

# JVM crash logs
hs_err_pid*
replay_pid*

# JVM profiling
*.hprof
*.jfr

# ===========================================
# MAVEN
# ===========================================
# Maven build directories
target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar

# Maven wrapper (keep the jar)
!.mvn/wrapper/maven-wrapper.jar

# ===========================================
# SPRING BOOT
# ===========================================
# Spring Boot specific
spring-boot-*.jar
spring-boot-*.war

# Spring Boot Actuator
/actuator/

# ===========================================
# DATABASES
# ===========================================
# H2 Database
*.h2.db
*.h2.db.trace.db
*.h2.db.lock.db

# SQLite
*.db
*.sqlite
*.sqlite3

# PostgreSQL
*.pgsql

# MySQL
*.mysql

# ===========================================
# CONTAINERS & DOCKER
# ===========================================
# Docker
.dockerignore
docker-compose.override.yml
docker-compose.local.yml

# Testcontainers
.testcontainers/

# ===========================================
# TESTING
# ===========================================
# Test results
TEST-*.xml
test-results/
build/reports/tests/
coverage/
*.lcov

# Testcontainers
.testcontainers/

# ===========================================
# SECURITY & SECRETS
# ===========================================
# Environment variables
.env
.env.local
.env.development
.env.test
.env.production
.env.staging

# Secrets and keys
*.key
*.pem
*.p12
*.jks
*.keystore
*.truststore

# Configuration files with secrets
application-secret.yml
application-secret.yaml
application-secret.properties
application-local.yml
application-local.yaml
application-local.properties
application-dev.yml
application-dev.yaml
application-dev.properties
application-prod.yml
application-prod.yaml
application-prod.properties

# ===========================================
# LOGS
# ===========================================
# Log files
*.log
logs/
log/

# Application logs
application.log
spring.log
netflix.log
microservices.log

# ===========================================
# IDEs & EDITORS
# ===========================================
# IntelliJ IDEA
.idea/
*.iws
*.iml
*.ipr
out/
!**/src/main/**/out/
!**/src/test/**/out/

# Eclipse
.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache
bin/
!**/src/main/**/bin/
!**/src/test/**/bin/

# NetBeans
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/

# VS Code
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json

# ===========================================
# OPERATING SYSTEMS
# ===========================================
# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.fseventsd
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# ===========================================
# TEMPORARY FILES
# ===========================================
# Temporary files
*.tmp
*.temp
*.swp
*.swo
*~
*.bak
*.backup
*.orig

# Temporary directories
tmp/
temp/
.tmp/
.temp/

# ===========================================
# PACKAGES & ARCHIVES
# ===========================================
# Package Files
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar
*.7z

# ===========================================
# RUNTIME & PROCESSES
# ===========================================
# Runtime data
pids
*.pid
*.seed
*.pid.lock

# ===========================================
# CACHES
# ===========================================
# Various caches
.cache/
.parcel-cache/
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/

# ===========================================
# NETFLIX SPECIFIC
# ===========================================
# Netflix specific files
netflix-*.properties
netflix-*.yml
netflix-*.yaml

# Netflix monitoring
netflix-monitoring/
netflix-metrics/

# Netflix security
netflix-security/
netflix-keys/

# ===========================================
# MICROSERVICES SPECIFIC
# ===========================================
# Service discovery
eureka-server/
service-registry/

# API Gateway
api-gateway/
gateway/

# Config Server
config-server/
config/

# Shared libraries
shared-libraries/
common/

# Monitoring
monitoring/
metrics/
tracing/

# Deployment
deployment/
k8s/
kubernetes/

# ===========================================
# BUILD TOOLS
# ===========================================
# Ant
build/
dist/
lib/

# ===========================================
# DOCUMENTATION
# ===========================================
# Generated documentation
docs/generated/
site/

# ===========================================
# MONITORING & PROFILING
# ===========================================
# Application monitoring
monitoring/
profiling/
metrics/

# ===========================================
# BACKUP FILES
# ===========================================
# Backup files
*.backup
*.bak
*.old
*.orig

# ===========================================
# VERSION CONTROL
# ===========================================
# Git
.git/
.gitignore.bak

# ===========================================
# DEPLOYMENT
# ===========================================
# Deployment artifacts
deploy/
deployment/
*.deployment

# ===========================================
# END OF NETFLIX PRODUCTION-GRADE MICROSERVICES .GITIGNORE
# ===========================================
